@model IEnumerable<SimpleShop.Models.Entities.ApplicationUser>

@{
    ViewData["Title"] = "Users";
}

<div class="container-fluid py-4">

    <h2 class="fw-bold mb-4">
        Users
    </h2>

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead>

                        <tr>

                            <th>
                                #
                            </th>

                            <th>
                                User Name
                            </th>

                            <th>
                                Email
                            </th>

                            <th>
                                Phone Number
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @{
                            int counter = 1;
                        }

                        @foreach (var user in Model)
                        {
                            <tr>

                                <td>
                                    @counter
                                </td>

                                <td>
                                    @user.UserName
                                </td>

                                <td>
                                    @user.Email
                                </td>

                                <td>
                                    @(user.PhoneNumber ?? "Not provided")
                                </td>

                            </tr>

                            counter++;
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>