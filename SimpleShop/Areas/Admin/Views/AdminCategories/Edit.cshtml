@model SimpleShop.Models.Entities.Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="container-fluid">

    <h2 class="mb-4">
        Edit Category
    </h2>

    <div class="card shadow-sm">

        <div class="card-body">

            <form asp-area="Admin"
                  asp-controller="AdminCategories"
                  asp-action="Edit"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       asp-for="Id" />

                <div class="mb-3">

                    <label asp-for="Name"
                           class="form-label">

                        Category Name

                    </label>

                    <input asp-for="Name"
                           class="form-control" />

                    <span asp-validation-for="Name"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="btn btn-primary">

                    Save Changes

                </button>

                <a asp-area="Admin"
                   asp-controller="AdminCategories"
                   asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial"
        );
    }

}