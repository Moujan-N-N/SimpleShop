@{
    ViewData["Title"] = "Manage Products";
}
@model IEnumerable<SimpleShop.Models.Entities.Product>
<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            Manage Products
        </h2>

        <a class="btn btn-danger">
            + New Product
        </a>

    </div>


    <div class="card shadow-sm">

        <div class="card-body">

            <h5>
                Products Management
            </h5>

            <p class="text-muted">
                Add, edit and delete products from here.
            </p>

        </div>

    </div>

</div>