@model SimpleShop.Models.Entities.Product

@{
    ViewData["Title"] = "Product Details";
}


<div class="container mt-4">

    <h2 class="mb-4">
        Product Details
    </h2>


    <div class="card shadow">

        <div class="card-body">


            <h4 class="card-title">
                @Model.Name
            </h4>


            <hr />


            <p>
                <strong>Price:</strong>
                @Model.Price $
            </p>


            <p>
                <strong>Stock:</strong>
                @Model.Stock
            </p>


            <p>
                <strong>Category:</strong>
                @Model.Category.Name
            </p>


            <p>
                <strong>Description:</strong>
                @Model.Description
            </p>


        </div>

    </div>


    <a asp-action="Index" class="btn btn-secondary mt-3">
        Back
    </a>

</div>