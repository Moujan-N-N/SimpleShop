@model SimpleShop.Models.Cart.ShoppingCart

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-5">

    <h2 class="mb-4">
        Shopping Cart
    </h2>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info">
            Your cart is empty.
        </div>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-primary">

            Continue Shopping

        </a>
    }
    else
    {
        <div class="row">

            <div class="col-lg-8">

                @foreach (var item in Model.Items)
                {
                    <div class="card mb-3 shadow-sm">

                        <div class="card-body">

                            <div class="row align-items-center">

                                <div class="col-md-3">
                                    <h5>
                                        @item.ProductName
                                    </h5>
                                </div>

                                <div class="col-md-2">
                                    <span>
                                        @item.Price.ToString("N0") $
                                    </span>
                                </div>

                                <div class="col-md-3">

                                    <div class="btn-group">

                                        <a asp-action="Decrease"
                                           asp-route-id="@item.ProductId"
                                           class="btn btn-outline-secondary">

                                            −

                                        </a>

                                        <span class="btn btn-light">
                                            @item.Quantity
                                        </span>

                                        <a asp-action="Increase"
                                           asp-route-id="@item.ProductId"
                                           class="btn btn-outline-secondary">

                                            +

                                        </a>

                                    </div>

                                </div>

                                <div class="col-md-2">

                                    <strong>
                                        @item.TotalPrice.ToString("N0") $
                                    </strong>

                                </div>

                                <div class="col-md-2">

                                    <a asp-action="Remove"
                                       asp-route-id="@item.ProductId"
                                       class="btn btn-danger btn-sm">

                                        Remove

                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>


            <div class="col-lg-4">

                <div class="card shadow">

                    <div class="card-body">

                        <h4>
                            Order Summary
                        </h4>

                        <hr />

                        <div class="d-flex justify-content-between">

                            <span>
                                Total:
                            </span>

                            <strong>
                                @Model.TotalAmount.ToString("N0") $
                            </strong>

                        </div>

                        <a asp-controller="Checkout"
                           asp-action="Index"
                           class="btn btn-success w-100 mt-4">

                            Checkout

                        </a>

                    </div>

                </div>

            </div>

        </div>
    }

</div>