@model SimpleShop.Models.Cart.ShoppingCart

@{
    ViewData["Title"] = "Shopping Cart";
}


<div class="container py-5">

    <h2 class="mb-4">
        🛒 Shopping Cart
    </h2>


    @if (!Model.Items.Any())
    {
        <div class="alert alert-warning">
            Your cart is empty.
        </div>
    }
    else
    {
        <table class="table table-bordered">

            <thead>
                <tr>
                    <th>
                        Product
                    </th>

                    <th>
                        Quantity
                    </th>

                    <th>
                        Price
                    </th>

                    <th>
                        Total
                    </th>

                    <th>
                    </th>
                </tr>
            </thead>


            <tbody>

                @foreach (var item in Model.Items)
                {
                    <tr>

                        <td>
                            @item.ProductName
                        </td>

                        <td>
                            @item.Quantity
                        </td>

                        <td>
                            @item.Price.ToString("N0")
                        </td>

                        <td>
                            @item.TotalPrice.ToString("N0")
                        </td>

                        <td>
                            <a asp-action="Remove"
                               asp-route-id="@item.ProductId"
                               class="btn btn-danger btn-sm">

                                Remove

                            </a>
                        </td>

                    </tr>
                }

            </tbody>

        </table>


        <h4 class="text-end">
            Total:
            @Model.TotalAmount.ToString("N0")
            تومان
        </h4>
    }

</div>