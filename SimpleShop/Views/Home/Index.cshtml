@model IEnumerable<SimpleShop.Models.Entities.Product>

@{
    ViewData["Title"] = "Home";
}

<div class="container py-4">

    <!-- Hero + Categories -->
    <div class="row g-4 mb-5">

        <!-- Categories Sidebar -->
        <div class="col-lg-3">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-danger text-white fw-bold">
                    Categories
                </div>

                <div class="list-group list-group-flush">


                    <a asp-area=""
                       asp-controller="Products"
                       asp-action="Index"
                       asp-route-categoryId="1"
                       class="list-group-item list-group-item-action">
                        💻 Laptops
                    </a>

                    <a asp-area=""
                       asp-controller="Products"
                       asp-action="Index"
                       asp-route-categoryId="2"
                       class="list-group-item list-group-item-action">
                        📱 Mobiles
                    </a>

                    <a asp-area=""
                       asp-controller="Products"
                       asp-action="Index"
                       asp-route-categoryId="3"
                       class="list-group-item list-group-item-action">
                        🖥 Accessories
                    </a>

                    <a asp-area=""
                       asp-controller="Products"
                       asp-action="Index"
                       asp-route-categoryId="4"
                       class="list-group-item list-group-item-action">
                        ⌚ Watches
                    </a>

                    <a asp-area=""
                       asp-controller="Products"
                       asp-action="Index"
                       asp-route-categoryId="5"
                       class="list-group-item list-group-item-action">
                        🎧 Headphones
                    </a>


                </div>

            </div>

        </div>

        <!-- Hero Banner -->
        <div class="col-lg-9">

            <div class="hero-section">

                <div class="row align-items-center">

                    <div class="col-lg-6">

                        <span class="badge bg-danger mb-3">
                            Summer Sale
                        </span>

                        <h1 class="display-5 fw-bold">
                            Upgrade Your Tech
                        </h1>

                        <p class="lead text-muted">
                            Discover quality products with great prices.
                        </p>

                        <a asp-controller="Products"
                           asp-action="Index"
                           class="btn btn-danger btn-lg">
                            Shop Now
                        </a>

                    </div>

                    <div class="col-lg-6 text-center">

                        <img src="~/images/hero.jpg"
                             class="img-fluid hero-image"
                             alt="Hero" />

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Featured Products -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            🔥 Featured Products
        </h2>

        <a asp-controller="Products"
           asp-action="Index"
           class="btn btn-outline-danger">
            View All
        </a>

    </div>

    <div class="row g-4">

        @foreach (var item in Model.Take(8))
        {
            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="card h-100 shadow-sm">

                    <img src="@item.ImageUrl"
                         class="card-img-top p-3"
                         style="height:220px; object-fit:contain;" />

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">
                            @item.Name
                        </h5>

                        <p class="text-muted mb-1">
                            @item.Description
                        </p>

                        <small class="text-secondary">
                            Category:
                            @item.Category?.Name
                        </small>

                        <h4 class="text-success mt-3">
                            @item.Price.ToString("N0") IRR
                        </h4>

                        <div class="mt-auto">

                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-primary w-100 mb-2">
                                View Details
                            </a>
                            <a asp-controller="Cart"
                               asp-action="Add"
                               asp-route-id="@item.Id"
                               class="btn btn-danger w-100">

                                🛒 Add To Cart

                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>